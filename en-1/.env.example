# Copy this file to .env and fill in your keys. Both are free, no credit card.

# Groq — free LLM API for script generation.
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Pexels — free stock video for b-roll.
# Get a key: https://www.pexels.com/api/
PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs — TTS API keys (comma-separated, key rotation otomatis)
# Get keys: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEYS=sk_xxxxxxxx,sk_yyyyyyyy,sk_zzzzzzzz
